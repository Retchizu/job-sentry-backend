# Path to the DistilBERT model checkpoint directory (contains model.safetensors)
JOBSENTRY_MODEL_ARTIFACT_PATH=thesis-scam-job-post/models/distilbert_run/checkpoint-1566

# Base model name for tokenizer and config (default: distilbert-base-uncased)
JOBSENTRY_MODEL_NAME=distilbert-base-uncased

# Maximum token sequence length for DistilBERT (default: 512)
JOBSENTRY_MAX_SEQUENCE_LENGTH=512

# Maximum number of job posts in a single batch-predict request (default: 50)
JOBSENTRY_MAX_BATCH_SIZE=50

# Confidence threshold for scam classification (default: 0.5)
JOBSENTRY_CONFIDENCE_THRESHOLD=0.5
