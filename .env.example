# Path to the DistilBERT model checkpoint directory (contains model.safetensors)
# Default: checkpoint-5412 (final training step)
JOBSENTRY_MODEL_ARTIFACT_PATH=thesis-scam-job-post/models/distilbert_run/checkpoint-5412

# Base model name for tokenizer and config (default: distilbert-base-uncased)
JOBSENTRY_MODEL_NAME=distilbert-base-uncased

# Maximum token sequence length for DistilBERT (default: 512)
JOBSENTRY_MAX_SEQUENCE_LENGTH=512

# Maximum number of job posts in a single batch-predict request (default: 50)
JOBSENTRY_MAX_BATCH_SIZE=50

# Confidence threshold for scam classification (default: 0.5)
JOBSENTRY_CONFIDENCE_THRESHOLD=0.5

# --- Hybrid model (optional) ---
# Set these to enable ensemble predictions alongside DistilBERT.
# When unset, the app uses DistilBERT only.

# Path to phase6_merged joblib pipeline (e.g. TF-IDF + LR/RF/XGB)
# JOBSENTRY_PHASE6_MERGED_PATH=

# Path to Bi-LSTM Keras model (.h5 or .keras)
# JOBSENTRY_BILSTM_ARTIFACT_PATH=

# Combination method for ensemble (default: soft_voting)
# JOBSENTRY_HYBRID_COMBINATION=soft_voting
